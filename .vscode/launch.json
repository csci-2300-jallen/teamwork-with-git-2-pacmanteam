{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch app",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "cwd": "${workspaceFolder}",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build",

      "osx": {
        "MIMode": "lldb",
      },

      "linux": {
        "MIMode": "gdb"
      },

      "windows": {
        "type": "cppvsdbg",
      }
    }
  ]
}